{
	"name": "worker-template",
	"type": "module",
	"scripts": {
		"dev": "wrangler dev",
		"cf-gen-types": "wrangler types --env-interface CloudflareBindings",
		"deploy": "pnpm run cf-gen-types && wrangler deploy --minify",
		"deploy:secrets": "wrangler secret bulk .dev.vars.production",
		"deploy:full": "pnpm run deploy && pnpm run deploy:secrets",
		"better-auth-gen-schema": "pnpm dlx @better-auth/cli@latest generate --config ./better-auth.config.ts --output ./src/db/schema/auth.ts",
		"cli": "tsx cli/cli.ts",
		"lint": "biome check --write --unsafe .",
		"type": "tsc -p tsconfig.json --noEmit",
		"dead": "knip",
		"check": "pnpm lint && pnpm type",
		"test": "vitest run",
		"db:seed": "tsx src/db/seeder/main.ts"
	},
	"dependencies": {
		"@hono/sentry": "^1.2.2",
		"@hono/zod-openapi": "^1.2.4",
		"@logtape/drizzle-orm": "^2.0.5",
		"@logtape/logtape": "^2.0.5",
		"@neondatabase/serverless": "^1.0.2",
		"@scalar/hono-api-reference": "^0.10.6",
		"@scalar/openapi-to-markdown": "^0.5.1",
		"@t3-oss/env-core": "^0.13.11",
		"bcrypt": "^6.0.0",
		"better-auth": "^1.6.0",
		"commander": "^14.0.3",
		"drizzle-orm": "^0.45.2",
		"drizzle-zod": "^0.8.3",
		"hono": "^4.12.12",
		"openapi-merge": "^1.3.3",
		"resend": "^6.10.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@faker-js/faker": "^10.4.0",
		"@types/node": "^25.5.2",
		"@types/service-worker-mock": "^2.0.4",
		"@vitest/coverage-v8": "^4.1.2",
		"drizzle-kit": "^0.31.10",
		"drizzle-seed": "^0.3.1",
		"inquirer": "^13.4.0",
		"knip": "^6.3.0",
		"lefthook": "^2.1.5",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2",
		"wrangler": "^4.80.0"
	}
}
